  "methodology": {
    "l1_latency_cycles": {
      "method": "Pointer-chasing micro-benchmark",
      "details": "Single-thread random-stride pointer chase with array size <= 16KB (fits in L1 cache). Measured clock cycles per access. Minimum latency across small array sizes taken as L1 latency."
    },
    "l2_latency_cycles": {
      "method": "Pointer-chasing micro-benchmark",
      "details": "Pointer chase with array sizes between L1 and L2 boundaries. Median latency in the \"L2 plateau\" region of the latency curve."
    },
    "dram_latency_cycles": {
      "method": "Pointer-chasing micro-benchmark",
      "details": "Pointer chase with array size >> L2 cache capacity. Random stride defeats prefetcher. Maximum stable latency at large array sizes."
    },
    "l2_cache_size_kb": {
      "method": "Latency curve inflection detection",
      "details": "Swept array sizes and measured access latency at each size. Identified the \"cliff\" where latency jumps from L2 to DRAM levels. The array size just before this transition equals L2 cache capacity."
    },
    "max_global_bandwidth_gbps": {
      "method": "Vectorized global memory read benchmark",
      "details": "Large array (64-512MB) read with float4 coalesced access. All SMs active. Maximum of multiple transfer sizes. CUDA events for wall-clock timing."
    },
    "max_shmem_bandwidth_gbps": {
      "method": "Shared memory bandwidth benchmark (aggregate)",
      "details": "One block per SM, 1024 threads/block, float4 reads from shared memory. Bank-conflict-free access pattern. CUDA events for wall-clock timing. Aggregate across all active SMs."
    },
    "actual_boost_clock_mhz": {
      "method": "clock64() / CUDA-event ratio under sustained FMA load",
      "details": "Ran 50M dependent FMA operations. Measured cycles via clock64() and wall-clock via CUDA events. Clock frequency = cycles / time. Includes 100K FMA warmup to reach stable boost state. Median of multiple trials for stability."
    },
    "max_shmem_per_block_kb": {
      "method": "Binary search with kernel launch attempts",
      "details": "Binary search over dynamic shared memory sizes. Uses cudaFuncSetAttribute for extended shared memory. Tests both default and opt-in limits. Finds maximum size where kernel launch succeeds."
    },
    "bank_conflict_penalty_cycles": {
      "method": "Controlled shared memory access stride comparison",
      "details": "Compared clock cycles for stride=1 (no bank conflict, 32 threads access 32 distinct banks) vs stride=32 (32-way conflict, all threads access bank 0). Penalty = conflict_cycles - no_conflict_cycles."
    },
    "num_active_sms": {
      "method": "Inline PTX %smid register detection",
      "details": "Launched 4096 blocks, each reporting its SM ID via asm(\"mov.u32 %0, %%smid\"). Counted unique SM IDs. This bypasses potentially spoofed cudaGetDeviceProperties."
    }
  }
}